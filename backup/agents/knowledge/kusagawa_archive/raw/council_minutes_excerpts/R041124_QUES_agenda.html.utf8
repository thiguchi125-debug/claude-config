  <tr>
    <td align="center" valign="top" height="1" width="33">１</td>
    <td align="center" valign="top" height="1" width="137"><a href="Search2.exe?Code=tz6dbsownceptcjp32&dMode=0&KeyWord=&searchMode=1&keyMode=10&fromYear=%97%DF%98a+4%94N&fromDate=%97%DF%98a+4%94N12%8C%8E%92%E8%97%E1%89%EF%81i%91%E63%93%FA12%8C%8E+7%93%FA%81j&tillYear=%97%DF%98a+4%94N&tillDate=%97%DF%98a+4%94N12%8C%8E%92%E8%97%E1%89%EF%81i%91%E63%93%FA12%8C%8E+7%93%FA%81j&speaker=%9FN%96%D8%91P%90m&speaker1=%9FN%96%D8%91P%90m&speaker2=&speaker3=&eTarget=1&AhitResult=%8C%9F%8D%F5" target="_top">櫻木　善仁</a><br>   
      （新和会）</td>
