  <tr>    
    <td align="center" valign="top" height="1" width="33">４</td>    
    <td align="center" valign="top" height="1" width="137"><a href="Search2.exe?Code=tz6dbsownceptcjp32&dMode=0&KeyWord=&searchMode=1&keyMode=10&fromYear=%97%DF%98a+4%94N&fromDate=%97%DF%98a+4%94N12%8C%8E%92%E8%97%E1%89%EF%81i%91%E64%93%FA12%8C%8E+8%93%FA%81j&tillYear=%97%DF%98a+4%94N&tillDate=%97%DF%98a+4%94N12%8C%8E%92%E8%97%E1%89%EF%81i%91%E64%93%FA12%8C%8E+8%93%FA%81j&speaker=%9FN%88%E4%90%B4%91%A0&speaker1=%9FN%88%E4%90%B4%91%A0&speaker2=&speaker3=&eTarget=1&AhitResult=%8C%9F%8D%F5" target="_top">櫻井　清蔵</a><br>    
