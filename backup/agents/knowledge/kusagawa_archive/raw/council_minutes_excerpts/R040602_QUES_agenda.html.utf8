    <td align="center" valign="top" height="1" width="137"><a href="Search2.exe?Code=tz6dbsownceptcjp32&dMode=0&KeyWord=&searchMode=1&keyMode=10&fromYear=%97%DF%98a+4%94N&fromDate=%97%DF%98a+4%94N+6%8C%8E%92%E8%97%E1%89%EF%81i%91%E64%93%FA+6%8C%8E15%93%FA%81j&tillYear=%97%DF%98a+4%94N&tillDate=%97%DF%98a+4%94N+6%8C%8E%92%E8%97%E1%89%EF%81i%91%E64%93%FA+6%8C%8E15%93%FA%81j&speaker=%91%90%90%EC%91%EC%96%E7&speaker1=%91%90%90%EC%91%EC%96%E7&speaker2=&speaker3=&eTarget=1&AhitResult=%8C%9F%8D%F5" target="_top">草川　卓也</a><br>  
