    <td align="center" valign="top" height="1" width="137"><a href="Search2.exe?Code=aoe02naolo728slxje&dMode=0&KeyWord=&searchMode=1&keyMode=10&fromYear=%95%BD%90%AC30%94N&fromDate=%95%BD%90%AC30%94N12%8C%8E%92%E8%97%E1%89%EF%81i%91%E64%93%FA12%8C%8E12%93%FA%81j&tillYear=%95%BD%90%AC30%94N&tillDate=%95%BD%90%AC30%94N12%8C%8E%92%E8%97%E1%89%EF%81i%91%E64%93%FA12%8C%8E12%93%FA%81j&speaker=%95%9F%91%F2%94%FC%97R%8BI&speaker1=%95%9F%91%F2%94%FC%97R%8BI&speaker2=&speaker3=&eTarget=1&AhitResult=%8C%9F%8D%F5" target="_top">福沢　美由紀</a><br>    
